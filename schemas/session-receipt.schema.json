{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/session-receipt.schema.json",
  "title": "Loom automatic runtime sealed receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "operation_id", "invocation_id",
               "project_id", "intent", "status", "code", "repeated",
               "reconciled_session_id", "selected_memory_ids", "selected_preference_ids",
               "outcome_ids", "adaptation_receipts", "improvement_evidence_ids", "tier", "domains",
               "reversible_action_ids", "archived_count", "uncertainty_codes",
               "owner_input_required", "user_message", "owner_message", "usage",
               "event_count", "world_fingerprint", "started_at", "completed_at",
               "receipt_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "session_id": {"type": "string", "format": "uuid"},
    "operation_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "invocation_id": {"type": "string", "format": "uuid"},
    "project_id": {"type": "string", "pattern": "^p-[0-9a-f]{32}$"},
    "intent": {"enum": ["plan", "resume", "execute", "review", "repair",
                        "close", "status", "remember", "forget", "why", "undo"]},
    "status": {"enum": ["completed", "blocked", "interrupted"]},
    "code": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "repeated": {"type": "boolean"},
    "reconciled_session_id": {"type": ["string", "null"], "format": "uuid"},
    "selected_memory_ids": {"type": "array", "items": {"type": "string"}},
    "selected_preference_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}},
    "outcome_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}},
    "adaptation_receipts": {"type": "array", "maxItems": 16,
      "items": {"type": "string", "minLength": 1, "maxLength": 300}},
    "improvement_evidence_ids": {"type": "array", "maxItems": 32,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"}},
    "tier": {"enum": ["S", "M", "L", "XL"]},
    "domains": {"type": "array", "minItems": 1, "maxItems": 16,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}},
    "reversible_action_ids": {"type": "array", "maxItems": 64,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"}},
    "archived_count": {"type": "integer", "minimum": 0},
    "uncertainty_codes": {"type": "array", "maxItems": 16,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"}},
    "owner_input_required": {"type": "boolean"},
    "user_message": {"type": "string", "maxLength": 1000},
    "owner_message": {"$ref": "owner-message.schema.json"},
    "usage": {"$ref": "#/$defs/usage"},
    "event_count": {"type": "integer", "minimum": 1, "maximum": 4096},
    "world_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "receipt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "measurement_status", "measurement_source",
        "processed_total_tokens", "normalization_reason"],
      "properties": {
        "schema_version": {"const": 3},
        "measurement_status": {"enum": ["provider-complete", "provider-partial",
          "host-complete", "host-partial", "unavailable", "invalid", "legacy-ambiguous"]},
        "measurement_source": {"type": ["string", "null"]},
        "capability_receipt_id": {"type": ["string", "null"]},
        "event_count": {"type": "integer", "minimum": 0, "maximum": 128},
        "events": {"type": "array", "maxItems": 128, "items": {"type": "object"}},
        "processed_total_tokens": {"type": ["integer", "null"], "minimum": 0},
        "normalization_reason": {"type": "string", "minLength": 1, "maxLength": 256},
        "receipt": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["provider", "model", "response_id", "captured_at",
            "raw_response_sha256", "attestation_status"],
          "properties": {
            "provider": {"type": "string"},
            "model": {"type": "string"},
            "response_id": {"type": "string"},
            "captured_at": {"type": "string", "format": "date-time"},
            "raw_response_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "attestation_status": {"const": "requires-independent-attestation"}
          }
        },
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "cache_read_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "tool_tokens": {"type": ["integer", "null"], "minimum": 0},
        "retry_tokens": {"type": ["integer", "null"], "minimum": 0},
        "legacy_declared_total_tokens": {"type": ["integer", "null"], "minimum": 0}
      }
    }
  }
}
