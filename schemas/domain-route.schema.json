{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/domain-route.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_version", "coverage_state", "composition", "active_task_domains", "memory_domains", "ambient_domains", "candidates", "rejected_alternatives", "missing_knowledge", "consequence", "subsystems", "graph_digest", "route_digest"],
  "properties": {
    "schema_version": {"const": 1},
    "policy_version": {"const": "domain-intelligence-v1"},
    "coverage_state": {"enum": ["known", "partial", "unknown", "conflicted", "stale", "unsupported"]},
    "composition": {"type": "boolean"},
    "active_task_domains": {"$ref": "#/$defs/domains"},
    "memory_domains": {"$ref": "#/$defs/domains"},
    "ambient_domains": {"$ref": "#/$defs/domains"},
    "candidates": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["domain", "coverage", "evidence", "source", "rank"], "properties": {"domain": {"$ref": "#/$defs/domain"}, "coverage": {"enum": ["known", "partial", "unknown", "conflicted", "stale", "unsupported"]}, "evidence": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}, "source": {"enum": ["request", "owner", "host-proposal", "adapter"]}, "rank": {"type": "integer", "minimum": 1, "maximum": 32}}}},
    "rejected_alternatives": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
    "missing_knowledge": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
    "consequence": {"type": "object", "additionalProperties": false, "required": ["class", "categories", "evidence"], "properties": {"class": {"enum": ["ordinary", "material", "high", "critical"]}, "categories": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}}, "evidence": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}}},
    "subsystems": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["id", "domains", "coverage", "consequence", "blocked"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}, "domains": {"$ref": "#/$defs/domains"}, "coverage": {"enum": ["known", "partial", "unknown", "conflicted", "stale", "unsupported"]}, "consequence": {"enum": ["ordinary", "material", "high", "critical"]}, "blocked": {"type": "boolean"}}}},
    "graph_digest": {"$ref": "#/$defs/digest"},
    "route_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "domain": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "domains": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/domain"}},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
