{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/repair-result.schema.json",
  "title": "Content-bound production repair result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repair_verification"],
  "properties": {
    "schema_version": {"const": 1},
    "repair_verification": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/verification"}
    }
  },
  "$defs": {
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "passed", "medium", "evidence_path", "evidence_sha256"],
      "properties": {
        "section": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "passed": {"const": true},
        "medium": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "evidence_path": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,255}$"},
        "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
