{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/repair-result.schema.json",
  "title": "Loom-executed production repair verification plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repair_verification"],
  "properties": {
    "schema_version": {"const": 2},
    "repair_verification": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {"$ref": "#/$defs/verification"}
    }
  },
  "$defs": {
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "medium", "command", "timeout_seconds"],
      "properties": {
        "section": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "medium": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "command": {"type": "array", "minItems": 1, "maxItems": 32,
          "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 300}
      }
    }
  }
}
