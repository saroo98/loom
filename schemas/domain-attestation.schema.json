{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "loom/schemas/domain-attestation.schema.json", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "attestation_id", "assertion", "asserted_authority", "authority_limits", "scope", "evidence", "decision_affected", "revalidate_by", "independence_status", "canonical_digest"],
  "properties": {"schema_version": {"const": 1}, "attestation_id": {"type": "string", "pattern": "^att-[0-9a-f]{16,64}$"}, "assertion": {"type": "string", "minLength": 1, "maxLength": 512}, "asserted_authority": {"type": "string", "minLength": 1, "maxLength": 128}, "authority_limits": {"type": "string", "minLength": 1, "maxLength": 512}, "scope": {"$ref": "domain-applicability.schema.json#/$defs/scope"}, "evidence": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}, "decision_affected": {"type": "string", "minLength": 1, "maxLength": 256}, "revalidate_by": {"type": ["string", "null"], "format": "date-time"}, "independence_status": {"enum": ["not-required", "host-asserted-unverified", "independently-verified"]}, "canonical_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}
}
