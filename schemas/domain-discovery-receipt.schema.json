{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "loom/schemas/domain-discovery-receipt.schema.json", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "discovery_id", "route_digest", "status", "questions", "answers", "retrieval_requests", "retrieval_rounds", "source_ids", "invariant_ids", "budgets", "usage", "created_at", "canonical_digest"],
  "properties": {
    "schema_version": {"const": 1}, "discovery_id": {"type": "string", "pattern": "^dsc-[0-9a-f]{16,64}$"}, "route_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "status": {"enum": ["needs-owner", "collecting-evidence", "gate-ready", "unsupported", "interrupted", "conflicted"]},
    "questions": {"type": "array", "maxItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["id", "question"], "properties": {"id": {"type": "string", "minLength": 1, "maxLength": 32}, "question": {"type": "string", "minLength": 1, "maxLength": 512}}}}, "answers": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 1024}, "maxProperties": 8},
    "retrieval_requests": {"type": "array", "maxItems": 20, "items": {"type": "object", "additionalProperties": false, "required": ["claim", "authority_classes", "scope", "output_contract"], "properties": {"claim": {"type": "string", "minLength": 1, "maxLength": 256}, "authority_classes": {"type": "array", "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64}}, "scope": {"type": "object", "additionalProperties": false, "properties": {}}, "output_contract": {"const": "domain-source.schema.json"}}}},
    "retrieval_rounds": {"type": "integer", "minimum": 0, "maximum": 2}, "source_ids": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "pattern": "^src-[0-9a-f]{16,64}$"}}, "invariant_ids": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^inv-[0-9a-f]{16,64}$"}},
    "budgets": {"$ref": "#/$defs/counts"}, "usage": {"$ref": "#/$defs/usage"}, "created_at": {"type": "string", "format": "date-time"}, "canonical_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "$defs": {"counts": {"type": "object", "additionalProperties": false, "required": ["questions", "retrieval_rounds", "sources", "invariants", "capsule_characters"], "properties": {"questions": {"const": 8}, "retrieval_rounds": {"const": 2}, "sources": {"const": 20}, "invariants": {"const": 32}, "capsule_characters": {"const": 8192}}}, "usage": {"type": "object", "additionalProperties": false, "required": ["questions", "retrieval_rounds", "sources", "invariants"], "properties": {"questions": {"type": "integer", "minimum": 0, "maximum": 8}, "retrieval_rounds": {"type": "integer", "minimum": 0, "maximum": 2}, "sources": {"type": "integer", "minimum": 0, "maximum": 20}, "invariants": {"type": "integer", "minimum": 0, "maximum": 32}}}}
}
