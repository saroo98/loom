{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"loom/schemas/score-trust-policy.schema.json",
  "type":"object","additionalProperties":false,"required":["schema_version","rubric_id","subject","issuers"],
  "properties":{
    "schema_version":{"const":1},"rubric_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},"subject":{"$ref":"#/$defs/subject"},
    "issuers":{"type":"array","minItems":1,"maxItems":32,"items":{"type":"object","additionalProperties":false,"required":["id","key_id","algorithm","modulus_hex","exponent","independent","evidence_classes","requirements"],"properties":{
      "id":{"type":"string","pattern":"^[a-z0-9._-]{1,128}$"},"key_id":{"type":"string","pattern":"^[a-z0-9._-]{1,128}$"},"algorithm":{"const":"rsa-pkcs1v15-sha256"},"modulus_hex":{"type":"string","pattern":"^[0-9a-f]{512,1024}$"},"exponent":{"type":"integer","minimum":3},"independent":{"const":true},
      "evidence_classes":{"type":"array","minItems":1,"maxItems":9,"uniqueItems":true,"items":{"enum":["matrix-reproduced","ci-reproduced","real-host","provider-attested","provider-native","host-observed","longitudinal-local","independently-witnessed","independent-external","public-adoption"]}},
      "requirements":{"type":"array","minItems":1,"maxItems":64,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z0-9-]{1,96}$"}}
    }}}
  },
  "$defs":{"subject":{"type":"object","additionalProperties":false,"required":["kind","repository","commit_sha","tree_sha256"],"properties":{"kind":{"enum":["source-tree","public-cut","competitor-revision"]},"repository":{"type":"string","minLength":1,"maxLength":256},"commit_sha":{"type":["string","null"],"pattern":"^[0-9a-f]{40}$"},"tree_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}}
}
