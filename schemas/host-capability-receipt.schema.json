{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/host-capability-receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "session_id", "protocol_version", "host", "host_version", "adapter_version", "runtime_version", "evidence_status", "detection_evidence", "usage_fields", "cache_evidence", "response_identity", "latency_events", "limitations"],
  "properties": {
    "schema_version": {"const": 2},
    "receipt_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "session_id": {"type": "string", "format": "uuid"},
    "protocol_version": {"const": 2},
    "host": {"type": "string", "minLength": 1, "maxLength": 128},
    "host_version": {"type": ["string", "null"], "maxLength": 128},
    "adapter_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "runtime_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "evidence_status": {"enum": ["contract-only", "simulated-conformant", "real-host-verified"]},
    "detection_evidence": {"type": "array", "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
    "usage_fields": {"type": "array", "maxItems": 32, "items": {"type": "string"}},
    "cache_evidence": {"type": "boolean"},
    "response_identity": {"type": "boolean"},
    "latency_events": {"type": "boolean"},
    "limitations": {"type": "array", "maxItems": 16, "items": {"type": "string", "maxLength": 256}}
  }
}
