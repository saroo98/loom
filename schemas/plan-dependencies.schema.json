{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/plan-dependencies.schema.json",
  "title": "Target-path to plan-section dependency map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sections"],
  "properties": {
    "schema_version": {"const": 1},
    "sections": {"type": "array", "minItems": 1, "maxItems": 128,
      "items": {"$ref": "#/$defs/section"}}
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target_patterns"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "target_patterns": {"type": "array", "minItems": 1,
          "items": {"type": "string", "minLength": 1, "maxLength": 300}}
      }
    }
  }
}
