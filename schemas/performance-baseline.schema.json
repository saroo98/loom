{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"loom/schemas/performance-baseline.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schema_version","baseline_id","source_commit","environment_digest","workloads","reason"],
  "properties":{
    "schema_version":{"const":1},"baseline_id":{"type":"string"},
    "source_commit":{"type":"string","pattern":"^[0-9a-f]{40}(?:[0-9a-f]{24})?$"},
    "environment_digest":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "workloads":{"type":"array","minItems":1},"reason":{"type":"string","minLength":1}
  }
}
