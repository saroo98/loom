{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"loom/schemas/score-rubric.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schema_version","rubric_id","title","evidence_classes","categories"],
  "properties":{
    "schema_version":{"const":1},
    "rubric_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},
    "title":{"type":"string","minLength":1,"maxLength":128},
    "evidence_classes":{"type":"array","minItems":1,"maxItems":16,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"}},
    "categories":{"type":"array","minItems":1,"maxItems":32,"items":{"$ref":"#/$defs/category"}}
  },
  "$defs":{
    "requirement":{"type":"object","additionalProperties":false,"required":["id","points","allowed_evidence_classes"],"properties":{
      "id":{"type":"string","pattern":"^[a-z0-9-]{1,96}$"},
      "points":{"type":"integer","minimum":1,"maximum":100},
      "allowed_evidence_classes":{"type":"array","minItems":1,"maxItems":8,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"}}
    }},
    "category":{"type":"object","additionalProperties":false,"required":["id","label","weight","requirements"],"properties":{
      "id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},
      "label":{"type":"string","minLength":1,"maxLength":96},
      "weight":{"type":"integer","minimum":1,"maximum":100},
      "requirements":{"type":"array","minItems":1,"maxItems":16,"items":{"$ref":"#/$defs/requirement"}}
    }}
  }
}
