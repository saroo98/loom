{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "loom/schemas/domain-invariant.schema.json", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "invariant_id", "statement", "invariant_type", "domain_ids", "subsystem_ids", "scope", "consequence", "authority_requirements", "supporting_source_ids", "contradicting_source_ids", "applicability_receipt_ids", "verification", "freshness", "evidence_state", "provenance_event_ids", "canonical_digest"],
  "properties": {
    "schema_version": {"const": 1}, "invariant_id": {"$ref": "#/$defs/id"}, "statement": {"type": "string", "minLength": 1, "maxLength": 512}, "invariant_type": {"enum": ["correctness", "safety", "regulatory", "interface", "release", "verification"]},
    "domain_ids": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}}, "subsystem_ids": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64}}, "scope": {"$ref": "domain-applicability.schema.json#/$defs/scope"},
    "consequence": {"type": "object", "additionalProperties": false, "required": ["class", "failure"], "properties": {"class": {"enum": ["ordinary", "material", "high", "critical"]}, "failure": {"type": "string", "minLength": 1, "maxLength": 512}}},
    "authority_requirements": {"type": "array", "maxItems": 8, "uniqueItems": true, "items": {"enum": ["repository-evidence", "executed-evidence", "official-law", "regulator", "official-vendor", "governing-standard", "primary-research", "qualified-reviewer", "owner-authority", "real-medium-evidence"]}},
    "supporting_source_ids": {"$ref": "#/$defs/ids"}, "contradicting_source_ids": {"$ref": "#/$defs/ids"}, "applicability_receipt_ids": {"$ref": "#/$defs/ids"},
    "verification": {"type": "object", "additionalProperties": false, "required": ["required_real_medium", "acceptance_target"], "properties": {"required_real_medium": {"type": "string", "minLength": 1, "maxLength": 256}, "acceptance_target": {"type": "string", "minLength": 1, "maxLength": 256}}},
    "freshness": {"type": "object", "additionalProperties": false, "required": ["policy_id", "as_of", "revalidate_by", "revision_identity"], "properties": {"policy_id": {"type": "string", "minLength": 1, "maxLength": 64}, "as_of": {"type": "string", "format": "date-time"}, "revalidate_by": {"type": "string", "format": "date-time"}, "revision_identity": {"type": ["string", "null"], "maxLength": 128}}},
    "evidence_state": {"enum": ["candidate", "supported", "gate-ready", "conflicted", "stale", "superseded", "quarantined"]}, "provenance_event_ids": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}, "canonical_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}-[0-9a-f]{16,64}$"}, "ids": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}}
}
