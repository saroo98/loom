{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/learning-candidate.schema.json",
  "title": "Explainable Loom memory admission candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "category", "domain", "project_id", "signal",
    "decision_target", "id", "status", "supports", "contradicts",
    "evidence_count", "evidence_ids", "evidence_projects", "confidence",
    "created_at", "last_evidence_at", "expires_at", "future_decision",
    "admitted_memory_id"],
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "scope": {"enum": ["global", "domain", "project"]},
    "category": {"enum": ["calibration", "process", "domain"]},
    "domain": {"type": ["string", "null"]},
    "project_id": {"type": ["string", "null"], "pattern": "^p-[0-9a-f]{32}$"},
    "signal": {"type": "string"},
    "decision_target": {"type": "string"},
    "status": {"enum": ["candidate", "active", "dormant", "stale", "archived", "forgotten", "superseded"]},
    "supports": {"type": "integer", "minimum": 0},
    "contradicts": {"type": "integer", "minimum": 0},
    "evidence_count": {"type": "integer", "minimum": 0},
    "evidence_ids": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string"}},
    "evidence_projects": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "pattern": "^p-[0-9a-f]{32}$"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "last_evidence_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "future_decision": {"type": "string"},
    "admitted_memory_id": {"type": ["string", "null"], "format": "uuid"}
  }
}
