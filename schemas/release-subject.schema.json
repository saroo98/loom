{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/release-subject.schema.json",
  "title": "Unified exact Loom release subject",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "commit", "tag", "release_sequence", "source_tree", "public_cut", "canonical_plugin", "helpers", "sboms", "workflows", "subject_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "repository": {"const": "https://github.com/saroo98/loom"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tag": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "release_sequence": {"type": "integer", "minimum": 1},
    "source_tree": {"$ref": "#/$defs/artifact"},
    "public_cut": {"$ref": "#/$defs/artifact"},
    "canonical_plugin": {"$ref": "#/$defs/artifact"},
    "helpers": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/artifact"}},
    "sboms": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/artifact"}},
    "workflows": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/artifact"}},
    "subject_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {"artifact": {"type": "object", "additionalProperties": false, "required": ["sha256", "bytes"], "properties": {"sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "bytes": {"type": "integer", "minimum": 1}}}}
}
