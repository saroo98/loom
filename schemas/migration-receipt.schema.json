{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/migration-receipt.schema.json",
  "title": "Lossless Loom vault migration receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["migration_id", "source_versions", "source_hashes", "before", "after", "reconciliation", "activated"],
  "properties": {
    "migration_id": {"type": "string", "format": "uuid"},
    "source_versions": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "maxLength": 32}},
    "source_hashes": {"type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "before": {"type": "object", "additionalProperties": false, "required": ["records", "tombstones", "outcomes", "preferences"], "properties": {"records": {"type": "integer", "minimum": 0}, "tombstones": {"type": "integer", "minimum": 0}, "outcomes": {"type": "integer", "minimum": 0}, "preferences": {"type": "integer", "minimum": 0}}},
    "after": {"type": "object", "additionalProperties": false, "required": ["records", "tombstones", "outcomes", "preferences"], "properties": {"records": {"type": "integer", "minimum": 0}, "tombstones": {"type": "integer", "minimum": 0}, "outcomes": {"type": "integer", "minimum": 0}, "preferences": {"type": "integer", "minimum": 0}}},
    "reconciliation": {"type": "array", "maxItems": 4096, "items": {"type": "object", "additionalProperties": false, "required": ["source_id", "target_id", "action", "reason"], "properties": {"source_id": {"type": "string", "minLength": 1, "maxLength": 128}, "target_id": {"type": ["string", "null"], "maxLength": 128}, "action": {"enum": ["preserved", "rekeyed", "dormant", "quarantined", "forgotten"]}, "reason": {"type": "string", "minLength": 1, "maxLength": 512}}}},
    "activated": {"type": "boolean"}
  }
}
