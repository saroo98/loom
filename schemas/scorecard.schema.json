{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"loom/schemas/scorecard.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schema_version","rubric_id","subject","evaluated_at","status","overall_score","evidence_records","categories","scorecard_sha256"],
  "properties":{
    "schema_version":{"const":1},"rubric_id":{"type":"string"},"subject":{"$ref":"#/$defs/subject"},
    "evaluated_at":{"type":"string","format":"date-time"},"status":{"enum":["local-evidence","certified"]},
    "overall_score":{"type":"number","minimum":0,"maximum":100},"evidence_records":{"type":"integer","minimum":0,"maximum":256},
    "categories":{"type":"array","minItems":1,"maxItems":32,"items":{"$ref":"#/$defs/category"}},
    "scorecard_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}
  },
  "$defs":{
    "subject":{"type":"object","additionalProperties":false,"required":["kind","repository","commit_sha","tree_sha256"],"properties":{"kind":{"enum":["source-tree","public-cut","competitor-revision"]},"repository":{"type":"string","minLength":1,"maxLength":256},"commit_sha":{"type":["string","null"],"pattern":"^[0-9a-f]{40}$"},"tree_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}},
    "category":{"type":"object","additionalProperties":false,"required":["id","label","weight","raw_score","weighted_score","awarded_requirements","withheld_requirements"],"properties":{"id":{"type":"string"},"label":{"type":"string"},"weight":{"type":"integer"},"raw_score":{"type":"number","minimum":0,"maximum":100},"weighted_score":{"type":"number","minimum":0,"maximum":100},"awarded_requirements":{"type":"array","maxItems":16,"items":{"type":"string"}},"withheld_requirements":{"type":"array","maxItems":16,"items":{"type":"string"}}}}
  }
}
