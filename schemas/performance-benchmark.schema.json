{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/performance-benchmark.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "measurement_kind", "seed", "warmups", "iterations", "environment", "results", "receipt_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "measurement_kind": {"const": "observed-local-offline"},
    "seed": {"type": "integer"}, "warmups": {"type": "integer", "minimum": 0},
    "iterations": {"type": "integer", "minimum": 1},
    "environment": {"type": "object"},
    "results": {"type": "array", "minItems": 1},
    "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
