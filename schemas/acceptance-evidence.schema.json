{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/acceptance-evidence.schema.json",
  "title": "Real-medium work-order acceptance evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "work_order", "medium", "command",
    "started_at", "completed_at", "exit_code", "stdout", "stderr", "stdout_sha256",
    "stderr_sha256", "raw_stdout_sha256", "raw_stderr_sha256", "transcript_minimized",
    "repo_state_before", "repo_state_after", "evidence_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "evidence_id": {"type": "string", "format": "uuid"},
    "work_order": {"type": "string", "pattern": "^WO-[0-9]{3,}$"},
    "medium": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "not": {"enum": ["checklist", "generic", "unknown", "document-review", "self-report"]}},
    "command": {"type": "array", "minItems": 1, "maxItems": 32,
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "exit_code": {"const": 0},
    "stdout": {"type": "string", "maxLength": 4096},
    "stderr": {"type": "string", "maxLength": 4096},
    "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "transcript_minimized": {"const": true},
    "repo_state_before": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repo_state_after": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
