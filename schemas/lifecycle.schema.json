{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/lifecycle.schema.json",
  "title": "Loom causal lifecycle record",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "baseline_files",
    "events",
    "work_order_completions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 2 },
    "mode": { "enum": ["planned", "build-first"] },
    "baseline_files": {
      "type": "object",
      "maxProperties": 100000,
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "event", "at", "repo_state_mode", "repo_state_hash",
              "repo_head", "previous_event_hash", "event_hash",
              "baseline_snapshot_sha256"
            ],
            "additionalProperties": false,
            "properties": {
              "event": { "const": "planning-started" },
              "at": { "type": "string", "format": "date-time" },
              "repo_state_mode": { "enum": ["git", "filesystem"] },
              "repo_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "repo_head": {
                "type": ["string", "null"],
                "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
              },
              "previous_event_hash": { "type": "null" },
              "event_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "baseline_snapshot_sha256": {
                "type": "string", "pattern": "^[0-9a-f]{64}$"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "event", "at", "repo_state_mode", "repo_state_hash",
              "repo_head", "previous_event_hash", "event_hash", "review",
              "review_sha256", "work_order_plans", "work_order_plans_sha256"
            ],
            "additionalProperties": false,
            "properties": {
              "event": { "const": "g1-sealed" },
              "at": { "type": "string", "format": "date-time" },
              "repo_state_mode": { "enum": ["git", "filesystem"] },
              "repo_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "repo_head": {
                "type": ["string", "null"],
                "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
              },
              "previous_event_hash": {
                "type": "string", "pattern": "^[0-9a-f]{64}$"
              },
              "event_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "review": { "type": "string", "minLength": 1 },
              "review_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "work_order_plans": {
                "type": "object",
                "minProperties": 1,
                "maxProperties": 10000,
                "additionalProperties": {
                  "type": "string", "pattern": "^[0-9a-f]{64}$"
                }
              },
              "work_order_plans_sha256": {
                "type": "string", "pattern": "^[0-9a-f]{64}$"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "event", "at", "repo_state_mode", "repo_state_hash",
              "repo_head", "previous_event_hash", "event_hash", "g1_event_hash"
            ],
            "additionalProperties": false,
            "properties": {
              "event": { "const": "implementation-authorized" },
              "at": { "type": "string", "format": "date-time" },
              "repo_state_mode": { "enum": ["git", "filesystem"] },
              "repo_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "repo_head": {
                "type": ["string", "null"],
                "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
              },
              "previous_event_hash": {
                "type": "string", "pattern": "^[0-9a-f]{64}$"
              },
              "event_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "g1_event_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        ]
      }
    },
    "work_order_completions": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "required": [
          "work_order", "work_order_file", "work_order_sha256", "completed_at",
          "repo_state_mode", "repo_state_hash", "repo_head", "changed_paths",
          "after_hashes", "acceptance_evidence", "acceptance_evidence_sha256",
          "previous_completion_hash", "completion_hash"
        ],
        "additionalProperties": false,
        "oneOf": [
          {
            "required": ["causal_scope"],
            "properties": {
              "causal_scope": { "const": "verification-only" },
              "changed_paths": { "maxItems": 0 },
              "after_hashes": { "maxProperties": 0 }
            }
          },
          {
            "properties": {
              "causal_scope": { "const": "implementation" },
              "changed_paths": { "minItems": 1 },
              "after_hashes": { "minProperties": 1 }
            }
          }
        ],
        "properties": {
          "work_order": { "type": "string", "pattern": "^WO-[0-9]{3,}$" },
          "work_order_file": { "type": "string", "minLength": 1 },
          "work_order_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "completed_at": { "type": "string", "format": "date-time" },
          "repo_state_mode": { "enum": ["git", "filesystem"] },
          "repo_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "repo_head": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"
          },
          "causal_scope": {
            "enum": ["implementation", "verification-only"]
          },
          "changed_paths": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "after_hashes": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "acceptance_evidence": {
            "type": "string", "pattern": "^evidence/WO-[0-9]{3,}\\.json$"
          },
          "acceptance_evidence_sha256": {
            "type": "string", "pattern": "^[0-9a-f]{64}$"
          },
          "previous_completion_hash": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{64}$"
          },
          "completion_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
