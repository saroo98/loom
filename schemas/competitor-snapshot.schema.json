{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"loom/schemas/competitor-snapshot.schema.json",
  "type":"object","additionalProperties":false,"required":["schema_version","project_id","project_name","canonical_repository","revision","accessed_at","expires_at","rubric_id","categories"],
  "properties":{
    "schema_version":{"const":1},"project_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},"project_name":{"type":"string","minLength":1,"maxLength":96},
    "canonical_repository":{"type":"string","pattern":"^https://github\\.com/[^/]+/[^/]+/?$"},"revision":{"type":"string","pattern":"^[0-9a-f]{40}$"},
    "accessed_at":{"type":"string","format":"date-time"},"expires_at":{"type":"string","format":"date-time"},"rubric_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},
    "categories":{"type":"array","minItems":1,"maxItems":32,"items":{"type":"object","additionalProperties":false,"required":["category_id","applicability","score","status","sources","rationale"],"properties":{
      "category_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},"applicability":{"enum":["applicable","not-applicable"]},"score":{"type":["number","null"],"minimum":0,"maximum":100},"status":{"enum":["verified","unverified","not-applicable"]},
      "sources":{"type":"array","maxItems":12,"uniqueItems":true,"items":{"type":"string","format":"uri"}},"rationale":{"type":"string","minLength":1,"maxLength":1000}
    }}}
  }
}
