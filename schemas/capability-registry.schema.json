{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/capability-registry.schema.json",
  "title": "Generated Loom capability registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "generated_by", "evidence_policy", "subject_digest", "evaluated_at", "capabilities"],
  "properties": {
    "schema_version": {"const": 2},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "generated_by": {"const": "tools/loom_capability_registry.py"},
    "evidence_policy": {"const": "loom-evidence-policy-v1"},
    "subject_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "evaluated_at": {"type": ["string", "null"], "format": "date-time"},
    "capabilities": {"type": "array", "items": {"$ref": "#/$defs/capability"}}
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "status", "enforcement", "tests", "evidence_ids", "limitations"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,95}$"},
        "kind": {"enum": ["mechanical", "advisory"]},
        "status": {"enum": ["supported", "experimental", "stale-proof", "unsupported", "unverified"]},
        "enforcement": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "tests": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
