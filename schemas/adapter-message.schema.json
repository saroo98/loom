{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/adapter-message.schema.json",
  "title": "Loom adapter protocol v2 message",
  "oneOf": [
    {"$ref": "#/$defs/initialize"},
    {"$ref": "#/$defs/initializeResult"},
    {"$ref": "#/$defs/invoke"},
    {"$ref": "#/$defs/requestEnvelope"},
    {"$ref": "#/$defs/complete"},
    {"$ref": "#/$defs/cancel"},
    {"$ref": "#/$defs/status"},
    {"$ref": "#/$defs/result"},
    {"$ref": "#/$defs/error"}
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$", "maxLength": 64},
    "hostVersion": {"type": "string", "minLength": 1, "maxLength": 128},
    "protocolRange": {
      "type": "object", "additionalProperties": false,
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "integer", "minimum": 1, "maximum": 255},
        "maximum": {"type": "integer", "minimum": 1, "maximum": 255}
      }
    },
    "capabilities": {
      "type": "object", "additionalProperties": false,
      "required": ["invoke", "complete", "cancel", "status", "markdown", "usage_receipt", "response_identity", "latency_events"],
      "properties": {
        "invoke": {"type": "boolean"},
        "complete": {"type": "boolean"},
        "cancel": {"type": "boolean"},
        "status": {"type": "boolean"},
        "markdown": {"type": "boolean"},
        "usage_receipt": {"type": "boolean"},
        "response_identity": {"type": "boolean"},
        "latency_events": {"type": "boolean"}
      }
    },
    "base": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id"],
      "properties": {
        "schema_version": {"const": 2},
        "message_type": {"type": "string"},
        "request_id": {"$ref": "#/$defs/id"}
      }
    },
    "initialize": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "protocol", "adapter", "host", "capabilities"],
      "properties": {
        "schema_version": {"const": 2},
        "message_type": {"const": "initialize"},
        "request_id": {"$ref": "#/$defs/id"},
        "protocol": {"$ref": "#/$defs/protocolRange"},
        "adapter": {
          "type": "object", "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {"id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/version"}}
        },
        "host": {
          "type": "object", "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {"id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/hostVersion"}}
        },
        "capabilities": {"$ref": "#/$defs/capabilities"}
      }
    },
    "initializeResult": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "protocol_version", "runtime_version", "release_sequence", "capabilities", "limitations"],
      "properties": {
        "schema_version": {"const": 2},
        "message_type": {"const": "initialize-result"},
        "request_id": {"$ref": "#/$defs/id"},
        "protocol_version": {"const": 2},
        "runtime_version": {"$ref": "#/$defs/version"},
        "release_sequence": {"type": "integer", "minimum": 1},
        "capabilities": {"$ref": "#/$defs/capabilities"},
        "limitations": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
      }
    },
    "invoke": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "request", "cwd"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "invoke"},
        "request_id": {"$ref": "#/$defs/id"},
        "request": {"type": "string", "minLength": 1, "maxLength": 32768},
        "cwd": {"type": "string", "minLength": 1, "maxLength": 4096}
      }
    },
    "requestIdentity": {
      "type": "object", "additionalProperties": false,
      "required": ["utf8_bytes", "sha256"],
      "properties": {
        "utf8_bytes": {"type": "integer", "minimum": 1, "maximum": 131072},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "lifecycleCapabilities": {
      "type": "object", "additionalProperties": false,
      "required": ["session_start", "pre_tool_guard", "post_tool_freshness", "compaction_resume", "automatic_learning", "subagent_propagation"],
      "properties": {
        "session_start": {"type": "boolean"},
        "pre_tool_guard": {"type": "boolean"},
        "post_tool_freshness": {"type": "boolean"},
        "compaction_resume": {"type": "boolean"},
        "automatic_learning": {"type": "boolean"},
        "subagent_propagation": {"type": "boolean"}
      }
    },
    "assurance": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "ingress", "request_identity_scope", "request_utf8_bytes", "request_sha256", "host_id", "host_version", "capability_receipt_sha256", "lifecycle_capabilities"],
      "properties": {
        "mode": {"enum": ["standard", "verified"]},
        "ingress": {"enum": ["codex-local-tool-v1", "codex-user-prompt-hook-v2"]},
        "request_identity_scope": {"enum": ["tool-argument", "host-prompt"]},
        "request_utf8_bytes": {"type": "integer", "minimum": 1, "maximum": 131072},
        "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "host_id": {"$ref": "#/$defs/id"},
        "host_version": {"$ref": "#/$defs/hostVersion"},
        "capability_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "lifecycle_capabilities": {"$ref": "#/$defs/lifecycleCapabilities"}
      }
    },
    "requestEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "request", "cwd", "host", "request_identity", "assurance"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "request-envelope"},
        "request_id": {"$ref": "#/$defs/id"},
        "request": {"type": "string", "minLength": 1, "maxLength": 32768},
        "cwd": {"type": "string", "minLength": 1, "maxLength": 4096},
        "host": {
          "type": "object", "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {"id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/hostVersion"}}
        },
        "request_identity": {"$ref": "#/$defs/requestIdentity"},
        "assurance": {"$ref": "#/$defs/assurance"}
      }
    },
    "complete": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "action", "usage", "result"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "complete"},
        "request_id": {"$ref": "#/$defs/id"},
        "action": {"type": "string", "minLength": 1, "maxLength": 4096},
        "usage": {"type": ["string", "null"], "maxLength": 4096},
        "result": {"type": ["string", "null"], "maxLength": 4096}
      }
    },
    "cancel": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "action"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "cancel"},
        "request_id": {"$ref": "#/$defs/id"},
        "action": {"type": "string", "minLength": 1, "maxLength": 4096}
      }
    },
    "status": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id"],
      "properties": {"schema_version": {"const": 2}, "message_type": {"const": "status"}, "request_id": {"$ref": "#/$defs/id"}}
    },
    "result": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "returncode", "payload"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "result"},
        "request_id": {"$ref": "#/$defs/id"}, "returncode": {"type": "integer", "minimum": 0, "maximum": 255},
        "payload": {"type": "object", "maxProperties": 128}
      }
    },
    "error": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "message_type", "request_id", "code", "message", "retryable"],
      "properties": {
        "schema_version": {"const": 2}, "message_type": {"const": "error"},
        "request_id": {"$ref": "#/$defs/id"},
        "code": {"enum": ["PROTOCOL_INCOMPATIBLE", "MESSAGE_INVALID", "MESSAGE_TOO_LARGE", "CAPABILITY_MISSING", "HOST_UNVERIFIED", "RUNTIME_BLOCKED", "RUNTIME_FAILED", "TIMEOUT", "CANCELLED"]},
        "message": {"type": "string", "minLength": 1, "maxLength": 512},
        "retryable": {"type": "boolean"}
      }
    }
  }
}
