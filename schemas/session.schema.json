{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/session.schema.json",
  "title": "Loom runtime session journal record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "session_id", "instance_id", "project_id", "request_hash",
    "invocation_id", "retry_key", "world_fingerprint", "intent", "domains",
    "started_at", "updated_at", "status", "commit_phase", "route_contract",
    "selected_memory_ids", "event_ids", "operation_ids", "reversible_action_ids",
    "receipt_id", "previous_session_id"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "session_id": { "type": "string", "format": "uuid" },
    "instance_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "pattern": "^p-[0-9a-f]{32}$" },
    "request_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "invocation_id": { "type": "string", "format": "uuid" },
    "retry_key": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "world_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "intent": {
      "enum": ["plan", "resume", "execute", "review", "repair", "close",
               "status", "remember", "forget", "why", "undo"]
    },
    "domains": {
      "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["open", "interrupted", "completed", "blocked"] },
    "commit_phase": { "enum": ["none", "prepared", "effects-applied", "receipt-sealed"] },
    "route_contract": { "$ref": "intent.schema.json#/properties/route_contract" },
    "selected_memory_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "event_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "operation_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "reversible_action_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "receipt_id": { "type": ["string", "null"], "format": "uuid" },
    "previous_session_id": { "type": ["string", "null"], "format": "uuid" }
  }
}
