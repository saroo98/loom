{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/host-contracts.schema.json",
  "title": "Loom versioned host contracts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "reviewed_at", "hosts"],
  "properties": {
    "schema_version": {"const": 2},
    "contract_id": {"const": "loom-host-contracts-v2"},
    "reviewed_at": {"type": "string", "format": "date"},
    "hosts": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "#/$defs/host"}}
  },
  "$defs": {
    "relativePath": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"},
    "stringList": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "surfaces", "global_roots", "canonical_root", "project_roots", "config_markers", "executables", "version_command", "headless_command", "precedence", "adapter_kind", "contract_status", "evidence_status", "proof_ttl_days", "sources", "update_operation", "uninstall_operation"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
        "surfaces": {"$ref": "#/$defs/stringList"},
        "global_roots": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"$ref": "#/$defs/relativePath"}},
        "canonical_root": {"$ref": "#/$defs/relativePath"},
        "project_roots": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/relativePath"}},
        "config_markers": {"type": "array", "maxItems": 8, "uniqueItems": true, "items": {"$ref": "#/$defs/relativePath"}},
        "executables": {"$ref": "#/$defs/stringList"},
        "version_command": {"$ref": "#/$defs/stringList"},
        "headless_command": {"$ref": "#/$defs/stringList"},
        "precedence": {"type": "string", "minLength": 1, "maxLength": 64},
        "adapter_kind": {"type": "string", "minLength": 1, "maxLength": 64},
        "contract_status": {"enum": ["documented", "experimental", "stale", "format-only", "unverified"]},
        "evidence_status": {"enum": ["simulated-conformant", "experimental", "unsupported", "real-host-verified"]},
        "proof_ttl_days": {"type": "integer", "minimum": 1, "maximum": 90},
        "sources": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
        "update_operation": {"type": "string", "minLength": 1, "maxLength": 128},
        "uninstall_operation": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    }
  }
}
