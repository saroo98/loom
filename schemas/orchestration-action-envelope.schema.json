{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/orchestration-action-envelope.schema.json",
  "title": "Persisted encrypted Loom orchestration action envelope v1",
  "description": "Closed outer JSON contract written to disk for an encrypted orchestration action. Ciphertext authenticity is verified by the owner-vault crypto backend with AAD bound to owner_vault_id and action_id.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "kind", "action_id", "owner_vault_id", "ciphertext"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "loom-encrypted-action-v1"},
    "action_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "owner_vault_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "ciphertext": {
      "type": "string",
      "minLength": 56,
      "maxLength": 349580,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
      "contentEncoding": "base64"
    }
  }
}
