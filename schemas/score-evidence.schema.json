{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"loom/schemas/score-evidence.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schema_version","subject","generated_at","artifacts","records"],
  "properties":{
    "schema_version":{"const":1},
    "subject":{"$ref":"#/$defs/subject"},
    "generated_at":{"type":"string","format":"date-time"},
    "artifacts":{"type":"object","maxProperties":32,"propertyNames":{"pattern":"^[a-z0-9-]{1,64}$"},"additionalProperties":{"type":"object","maxProperties":64}},
    "records":{"type":"array","maxItems":256,"items":{"$ref":"#/$defs/record"}}
  },
  "$defs":{
    "sha":{"type":"string","pattern":"^[0-9a-f]{64}$"},
    "subject":{"type":"object","additionalProperties":false,"required":["kind","repository","commit_sha","tree_sha256"],"properties":{
      "kind":{"enum":["source-tree","public-cut","competitor-revision"]},
      "repository":{"type":"string","minLength":1,"maxLength":256},
      "commit_sha":{"type":["string","null"],"pattern":"^[0-9a-f]{40}$"},
      "tree_sha256":{"$ref":"#/$defs/sha"}
    }},
    "record":{"type":"object","additionalProperties":false,"required":["schema_version","evidence_id","coverage_id","subject","evidence_class","status","requirement_id","source","observed_at","expires_at","attestation","digest"],"properties":{
      "schema_version":{"const":1},
      "evidence_id":{"type":"string","pattern":"^ev-[0-9a-f]{32}$"},
      "coverage_id":{"type":"string","pattern":"^[a-z0-9:._-]{1,160}$"},
      "subject":{"$ref":"#/$defs/subject"},
      "evidence_class":{"enum":["mechanical-local","matrix-reproduced","real-host","provider-attested","longitudinal-local","independent-external","public-adoption","claimed-only"]},
      "status":{"enum":["passed","failed","unverified"]},
      "requirement_id":{"type":"string","pattern":"^[a-z0-9-]{1,96}$"},
      "source":{"type":"object","additionalProperties":false,"required":["tool","locator","artifact_id","artifact_sha256"],"properties":{
        "tool":{"type":"string","minLength":1,"maxLength":96},
        "locator":{"type":"string","minLength":1,"maxLength":256},
        "artifact_id":{"type":"string","pattern":"^[a-z0-9-]{1,64}$"},
        "artifact_sha256":{"$ref":"#/$defs/sha"}
      }},
      "observed_at":{"type":"string","format":"date-time"},
      "expires_at":{"type":["string","null"],"format":"date-time"},
      "attestation":{"oneOf":[{"type":"null"},{"type":"object","additionalProperties":false,"required":["algorithm","key_id","signature"],"properties":{"algorithm":{"const":"rsa-pkcs1v15-sha256"},"key_id":{"type":"string","pattern":"^[a-z0-9._-]{1,128}$"},"signature":{"type":"string","minLength":1,"maxLength":2048}}}]},
      "digest":{"$ref":"#/$defs/sha"}
    }}
  }
}
