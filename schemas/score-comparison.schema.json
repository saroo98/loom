{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"loom/schemas/score-comparison.schema.json",
  "type":"object","additionalProperties":false,"required":["schema_version","rubric_id","evaluated_at","projects","comparison_sha256"],
  "properties":{
    "schema_version":{"const":1},"rubric_id":{"type":"string"},"evaluated_at":{"type":"string","format":"date-time"},
    "projects":{"type":"array","minItems":2,"maxItems":16,"items":{"type":"object","additionalProperties":false,"required":["project_id","project_name","known_score","lower_bound","upper_bound","evidence_coverage","unverified_categories"],"properties":{
      "project_id":{"type":"string"},"project_name":{"type":"string"},"known_score":{"type":["number","null"],"minimum":0,"maximum":100},"lower_bound":{"type":"number","minimum":0,"maximum":100},"upper_bound":{"type":"number","minimum":0,"maximum":100},"evidence_coverage":{"type":"number","minimum":0,"maximum":100},"unverified_categories":{"type":"array","maxItems":32,"items":{"type":"string"}}
    }}},
    "comparison_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}
  }
}
