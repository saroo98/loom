{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/planning-intelligence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_version", "universal_lenses", "verification_defaults", "evidence_roles", "lifecycle_route", "program", "active_modules", "dormant_modules", "atoms", "composition", "intelligence_digest"],
  "properties": {
    "schema_version": {"const": 1},
    "policy_version": {"const": "planning-intelligence-v1"},
    "universal_lenses": {"type": "array", "const": ["outcome", "scope", "epistemics", "consequence-reversibility", "dependencies", "acceptance-medium", "release-rollback"]},
    "verification_defaults": {"type": "object", "additionalProperties": false, "required": ["risk", "failure_mode", "environment", "fixture_data", "oracle", "rollback_signal", "freshness"], "properties": {"risk": {"type": "string", "minLength": 1, "maxLength": 160}, "failure_mode": {"type": "string", "minLength": 1, "maxLength": 200}, "environment": {"type": "string", "minLength": 1, "maxLength": 160}, "fixture_data": {"type": "string", "minLength": 1, "maxLength": 200}, "oracle": {"type": "string", "minLength": 1, "maxLength": 200}, "rollback_signal": {"type": "string", "minLength": 1, "maxLength": 200}, "freshness": {"type": "string", "minLength": 1, "maxLength": 200}}},
    "evidence_roles": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["index", "role", "clause_digest", "evidence"], "properties": {"index": {"type": "integer", "minimum": 0, "maximum": 31}, "role": {"enum": ["target", "constraint", "source-material", "excluded", "context"]}, "clause_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "evidence": {"enum": ["source-marker", "negation", "action-verb", "constraint-term", "context-only"]}}}},
    "lifecycle_route": {"type": "object", "additionalProperties": false, "required": ["mode", "evidence"], "properties": {"mode": {"enum": ["project", "incident", "maintenance"]}, "evidence": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 160}}}},
    "program": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "lifecycle_mode", "initial_state", "milestone_graph", "program_digest"], "properties": {"schema_version": {"const": 1}, "lifecycle_mode": {"enum": ["project", "incident", "maintenance"]}, "initial_state": {"enum": ["planned", "detected", "proposed"]}, "milestone_graph": {"type": "object"}, "program_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}}]},
    "active_modules": {"type": "array", "maxItems": 7, "items": {"type": "object", "additionalProperties": false, "required": ["id", "version", "content_digest", "evidence", "atom_ids"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"}, "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "content_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "evidence": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 160}}, "atom_ids": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:-]{0,127}$"}}}}},
    "dormant_modules": {"type": "array", "maxItems": 7, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"}},
    "atoms": {"type": "array", "maxItems": 24, "items": {"type": "object", "additionalProperties": false, "required": ["atom_id", "module_id", "kind", "statement", "scope", "consequence", "evidence", "provenance", "gate_effect", "required_real_medium", "verification"], "properties": {"atom_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:-]{0,127}$"}, "module_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"}, "kind": {"enum": ["constraint", "recommendation", "question", "alternative", "current-fact-query", "unknown-blocker", "risk", "decision-requirement", "artifact-requirement", "work-order-constraint", "verification-obligation", "release-gate"]}, "statement": {"type": "string", "minLength": 1, "maxLength": 320}, "scope": {"const": "active-task"}, "consequence": {"enum": ["ordinary", "material", "high", "critical"]}, "evidence": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 160}}, "provenance": {"type": "string", "pattern": "^module:[a-z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+#sha256:[0-9a-f]{64}$"}, "gate_effect": {"enum": ["none", "plan", "affected-branch", "acceptance", "release", "consequence-dependent"]}, "required_real_medium": {"type": "string", "minLength": 1, "maxLength": 200}, "verification": {"type": "object", "additionalProperties": false, "required": ["observation_method", "evidence_artifact"], "properties": {"observation_method": {"type": "string", "minLength": 1, "maxLength": 200}, "evidence_artifact": {"type": "string", "pattern": "^plans/evidence/[a-z0-9-]+\\.json$"}}}}}},
    "composition": {"type": "object", "additionalProperties": false, "required": ["nodes", "edges", "conflicts", "graph_digest"], "properties": {"nodes": {"type": "array", "maxItems": 24, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:-]{0,127}$"}}, "edges": {"type": "array", "maxItems": 24, "items": {"type": "object", "additionalProperties": false, "required": ["from", "to", "kind"], "properties": {"from": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"}, "to": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:-]{0,127}$"}, "kind": {"const": "emits"}}}}, "conflicts": {"type": "array", "maxItems": 16, "items": {"type": "object"}}, "graph_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}},
    "intelligence_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
