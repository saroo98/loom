{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/host-discovery-receipt.schema.json",
  "title": "Loom host discovery receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "contract_reviewed_at", "host", "surfaces", "contract_status", "contract_evidence_status", "proof_ttl_days", "sources", "status", "evidence_class", "version", "binary_sha256", "version_command", "limitations"],
  "properties": {
    "schema_version": {"const": 2},
    "contract_id": {"const": "loom-host-contracts-v2"},
    "contract_reviewed_at": {"type": "string", "format": "date"},
    "host": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
    "surfaces": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64}},
    "contract_status": {"enum": ["documented", "experimental", "stale", "format-only", "unverified"]},
    "contract_evidence_status": {"enum": ["simulated-conformant", "experimental", "unsupported", "real-host-verified"]},
    "proof_ttl_days": {"type": "integer", "minimum": 1, "maximum": 90},
    "sources": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
    "status": {"enum": ["detected", "not-detected", "unverified"]},
    "evidence_class": {"const": "host-observed"},
    "version": {"type": ["string", "null"], "maxLength": 128},
    "binary_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "version_command": {"type": ["array", "null"], "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 1024}},
    "limitations": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "minLength": 1, "maxLength": 256}}
  }
}
