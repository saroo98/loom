{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/memory-record.schema.json",
  "title": "Scoped Loom owner-memory record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "scope", "category", "statement", "provenance", "evidence_count",
    "confidence", "domain", "project_id", "created_at", "last_confirmed",
    "expires_at", "status", "supersedes", "preference_key", "preference_value",
    "last_selected", "last_applied", "last_helped", "last_hurt",
    "selection_count", "application_count", "helped_count", "hurt_count",
    "evidence_projects", "utility_score", "verify_by"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "scope": { "enum": ["global", "domain", "project", "temporary"] },
    "category": { "enum": ["preference", "calibration", "process", "domain"] },
    "statement": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "provenance": { "enum": ["stated", "observed", "inferred"] },
    "evidence_count": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "domain": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "project_id": { "type": ["string", "null"], "pattern": "^p-[0-9a-f]{32}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_confirmed": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "status": { "enum": ["active", "dormant", "stale", "archived", "forgotten", "superseded"] },
    "supersedes": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "preference_key": { "type": ["string", "null"] },
    "preference_value": { "type": ["string", "null"] },
    "last_selected": { "type": ["string", "null"], "format": "date-time" },
    "last_applied": { "type": ["string", "null"], "format": "date-time" },
    "last_helped": { "type": ["string", "null"], "format": "date-time" },
    "last_hurt": { "type": ["string", "null"], "format": "date-time" },
    "selection_count": { "type": "integer", "minimum": 0 },
    "application_count": { "type": "integer", "minimum": 0 },
    "helped_count": { "type": "integer", "minimum": 0 },
    "hurt_count": { "type": "integer", "minimum": 0 },
    "evidence_projects": { "type": "array", "maxItems": 64, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^p-[0-9a-f]{32}$" } },
    "utility_score": { "type": "number", "minimum": -1, "maximum": 1 },
    "verify_by": { "type": ["string", "null"], "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "scope": { "const": "global" } } },
      "then": {
        "properties": {
          "category": { "enum": ["preference", "calibration", "process"] },
          "domain": { "type": "null" },
          "project_id": { "type": "null" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "domain" } } },
      "then": {
        "properties": {
          "domain": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
          "project_id": { "type": "null" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "project" } } },
      "then": {
        "properties": {
          "domain": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
          "project_id": { "type": "string", "pattern": "^p-[0-9a-f]{32}$" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "active" },
          "category": { "const": "preference" }
        },
        "required": ["status", "category"]
      },
      "then": {
        "properties": {
          "provenance": { "const": "stated" },
          "preference_key": { "type": "string", "minLength": 1 },
          "preference_value": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": { "enum": ["calibration", "process", "domain"] }
        },
        "required": ["category"]
      },
      "then": {
        "properties": {
          "preference_key": { "type": "null" },
          "preference_value": { "type": "null" }
        }
      }
    }
  ]
}
