{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/memory-record.schema.json",
  "title": "Scoped Loom owner-memory record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "scope", "category", "statement", "provenance", "evidence_count",
    "confidence", "domain", "project_id", "created_at", "status",
    "preference_key", "preference_value"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "scope": { "enum": ["general", "global", "domain", "project", "component", "temporary", "device"] },
    "category": { "enum": ["preference", "calibration", "process", "domain", "owner-preference", "communication", "workflow-calibration", "decision-economics", "domain-invariant", "technical-fact"] },
    "statement": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "provenance": { "enum": ["stated", "observed", "inferred"] },
    "evidence_count": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "domain": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "project_id": { "type": ["string", "null"], "pattern": "^p-[0-9a-f]{32}$" },
    "component_id": { "type": ["string", "null"], "pattern": "^c-[0-9a-f]{32}$" },
    "device_id": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "status": { "enum": ["candidate", "active", "dormant", "revalidation-required", "archived", "superseded", "quarantined", "forgotten"] },
    "preference_key": { "type": ["string", "null"] },
    "preference_value": { "type": ["string", "null"] },
    "verify_by": { "type": ["string", "null"], "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "scope": { "enum": ["general", "global"] } } },
      "then": {
        "properties": {
          "category": { "enum": ["preference", "calibration", "process"] },
          "domain": { "type": "null" },
          "project_id": { "type": "null" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "domain" } } },
      "then": {
        "properties": {
          "domain": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
          "project_id": { "type": "null" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "project" } } },
      "then": {
        "properties": {
          "domain": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
          "project_id": { "type": "string", "pattern": "^p-[0-9a-f]{32}$" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "component" } }, "required": ["scope"] },
      "then": {
        "required": ["component_id"],
        "properties": {
          "domain": { "type": "string" },
          "project_id": { "type": "string", "pattern": "^p-[0-9a-f]{32}$" },
          "component_id": { "type": "string", "pattern": "^c-[0-9a-f]{32}$" }
        }
      }
    },
    {
      "if": { "properties": { "scope": { "const": "temporary" } }, "required": ["scope"] },
      "then": { "required": ["expires_at"] }
    },
    {
      "if": { "properties": { "scope": { "const": "device" } }, "required": ["scope"] },
      "then": {
        "required": ["device_id"],
        "properties": { "domain": { "type": "null" }, "project_id": { "type": "null" } }
      }
    },
    {
      "if": { "properties": { "category": { "const": "technical-fact" } }, "required": ["category"] },
      "then": { "required": ["verify_by"] }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "active" },
          "category": { "const": "preference" }
        },
        "required": ["status", "category"]
      },
      "then": {
        "properties": {
          "provenance": { "const": "stated" },
          "preference_key": { "type": "string", "minLength": 1 },
          "preference_value": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": { "enum": ["calibration", "process", "domain"] }
        },
        "required": ["category"]
      },
      "then": {
        "properties": {
          "preference_key": { "type": "null" },
          "preference_value": { "type": "null" }
        }
      }
    }
  ]
}
