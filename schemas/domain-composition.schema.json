{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loom/schemas/domain-composition.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "nodes", "edges", "consequence", "graph_digest"],
  "properties": {
    "schema_version": {"const": 1},
    "nodes": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["id", "domains", "coverage", "consequence", "blocked"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}, "domains": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}}, "coverage": {"enum": ["known", "partial", "unknown", "conflicted", "stale", "unsupported"]}, "consequence": {"enum": ["ordinary", "material", "high", "critical"]}, "blocked": {"type": "boolean"}}}},
    "edges": {"type": "array", "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["from", "to", "kind", "consequence", "blocked"], "properties": {"from": {"type": "string", "minLength": 1, "maxLength": 64}, "to": {"type": "string", "minLength": 1, "maxLength": 64}, "kind": {"enum": ["data-flow", "control-flow", "material-flow", "shared-interface", "depends-on"]}, "consequence": {"enum": ["ordinary", "material", "high", "critical"]}, "blocked": {"type": "boolean"}}}},
    "consequence": {"type": "object", "additionalProperties": false, "required": ["class", "categories", "evidence"], "properties": {"class": {"enum": ["ordinary", "material", "high", "critical"]}, "categories": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}}, "evidence": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 256}}}},
    "graph_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
